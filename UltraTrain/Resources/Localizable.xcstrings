        }
      }
    },
    "When enabled, an SOS button appears during active runs. Pressing it triggers an alert to your emergency contacts.": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quand activé, un bouton SOS apparaît pendant les courses. L'appuyer déclenche une alerte à vos contacts d'urgence."
