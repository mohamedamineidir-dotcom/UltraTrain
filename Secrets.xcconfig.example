// Secrets.xcconfig — Copy this file to Secrets.xcconfig and fill in your values
// DO NOT commit Secrets.xcconfig to git (it is gitignored)

// Strava API credentials (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID = your_strava_client_id
STRAVA_CLIENT_SECRET = your_strava_client_secret

// HMAC signing secret (must match backend HMAC_SECRET environment variable)
HMAC_SIGNING_SECRET = your_hmac_signing_secret
